PORT=3000

DB_HOST=localhost
# Usa 5432 como base. Si tu instalación local usa otro puerto, por ejemplo PostgreSQL 18 en Windows, cámbialo aquí.
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=change-me
DB_DATABASE=vera
DB_SCHEMA=public
DB_LOGGING=false
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
JWT_SECRET=change-me
JWT_EXPIRES_IN=8h

# Fase 3 - almacenamiento documental
# `LOCAL_PATH` sirve para desarrollo y pruebas dentro del workspace.
# `OBJECT_STORAGE` usa un bucket S3-compatible como estrategia estable.
DOCUMENTS_STORAGE_DRIVER=LOCAL_PATH
DOCUMENTS_STORAGE_ROOT=.storage/documents
DOCUMENTS_S3_ENDPOINT=
DOCUMENTS_S3_REGION=us-east-1
DOCUMENTS_S3_BUCKET=vera-documents
DOCUMENTS_S3_ACCESS_KEY_ID=change-me
DOCUMENTS_S3_SECRET_ACCESS_KEY=change-me
DOCUMENTS_S3_FORCE_PATH_STYLE=true
DOCUMENTS_S3_PREFIX=documents
